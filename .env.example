# ─────────────────────────────────────────────
#  WAKANECT — Variables d'environnement
# ─────────────────────────────────────────────

# Serveur
PORT=
NODE_ENV=

# MongoDB Atlas
MONGODB_URI=

# Meta / WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=

# Auth JWT
JWT_SECRET=
JWT_EXPIRES_IN=30d

# App
APP_URL=
FRONTEND_URL=

# ── Parser en cascade ──────────────────────────────────────────────────────────

# Cloudflare Workers AI (gratuit, tier 1 IA)
# Créer un token sur https://dash.cloudflare.com/profile/api-tokens
# Scope requis : AI Gateway → Read + Run
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Modèle Workers AI utilisé pour le parsing (valeur par défaut si absent)
CF_MODEL=@cf/meta/llama-3.1-8b-instruct

# Anthropic — Claude Haiku (dernier recours, prompt caching actif)
ANTHROPIC_API_KEY=

# ── Cloudflare R2 (stockage images produits) ──────────────────────────────────
# Account ID visible sur https://dash.cloudflare.com/ → R2 → Overview
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# URL publique du bucket R2 (domaine r2.dev OU domaine perso Cloudflare).
# ÉTAPE MANUELLE : activer "Public access" dans R2 → bucket → Settings,
# puis copier l'URL ici (sans slash final).
# Ex: https://pub-xxxx.r2.dev  ou  https://images.mon-domaine.com
R2_PUBLIC_URL_BASE=

# Version Graph API WhatsApp (défaut : v19.0)
# WHATSAPP_GRAPH_API_VERSION=v19.0

# Fenêtre d'association image→produit en secondes (défaut : 120)
# ASSOCIATION_WINDOW_S=120

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Générer UNE FOIS avec : node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
# Ne jamais régénérer après déploiement (les subscriptions existantes deviendraient invalides).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Format : mailto:admin@votredomaine.com  OU  https://votredomaine.com
VAPID_SUBJECT=

# ── Back-office Superadmin ────────────────────────────────────────────────────
# Numéro normalisé sans '+' (ex: 221770000000). Utilisé pour le login admin.
SUPERADMIN_PHONE=
# Mot de passe du compte superadmin (hashé au seed, jamais stocké en clair).
SUPERADMIN_PASSWORD=

# ── Numéro WhatsApp Wakanect (affiché dans la config publique et les DTOs) ────
# Format normalisé sans '+' (ex: 221770000000)
WAKANECT_WHATSAPP_NUMBER=

# ── PayDunya SoftPay (paiements abonnements) ──────────────────────────────────
# Clés disponibles sur https://app.paydunya.com → Mon compte → Clés API
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
# "test" pour le sandbox PayDunya, "live" pour la production
PAYDUNYA_MODE=test

# ── Alertes admin (seuils ajustables après pilote) ───────────────────────────
# Appels Haiku par boutique par jour avant alerte 'danger'
ALERT_HAIKU_CALLS_PER_SHOP_DAY=100
# % d'escalade vers Haiku sur 24h avant alerte 'warning'
ALERT_HAIKU_ESCALATION_PCT_24H=45
# Budget Haiku journalier en FCFA avant alerte 'danger'
ALERT_HAIKU_DAILY_BUDGET_FCFA=1000

# ── Taux de change USD → FCFA (pour affichage des coûts Haiku en FCFA) ───────
USD_TO_FCFA_RATE=600
